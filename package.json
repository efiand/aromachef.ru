{
	"dependencies": {
		"@dotenvx/dotenvx": "1.66.0",
		"bcrypt-ts": "8.0.1",
		"dompurify": "3.4.4",
		"formidable": "3.5.4",
		"html-minifier-terser": "7.2.0",
		"jsdom": "29.1.1",
		"jsonwebtoken": "9.0.3",
		"mysql2": "3.22.3",
		"sharp": "0.34.5",
		"typograf": "7.7.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@fastify/pre-commit": "2.2.1",
		"@types/amphtml-validator": "1.0.4",
		"@types/formidable": "3.5.1",
		"@types/html-minifier-terser": "7.0.2",
		"@types/jsdom": "28.0.3",
		"@types/jsonwebtoken": "9.0.10",
		"@types/node": "25.8.0",
		"@types/postcss-import": "14.0.3",
		"@types/postcss-url": "10.0.4",
		"amphtml-validator": "1.0.38",
		"cssnano": "8.0.1",
		"fast-xml-parser": "5.8.0",
		"fast-xml-validator": "1.1.0",
		"html-validate": "11.2.0",
		"nodemon": "3.1.14",
		"petite-vue": "0.4.1",
		"postcss": "8.5.14",
		"postcss-cli": "11.0.1",
		"postcss-import": "16.1.1",
		"postcss-sort-media-queries": "6.6.1",
		"postcss-url": "10.1.3",
		"posthtml-bem-linter": "0.1.8",
		"rolldown": "1.0.1",
		"tinymce": "8.5.0",
		"typescript": "6.0.3"
	},
	"imports": {
		"#client/*": "./src/client/*",
		"#common/*": "./app/common/*",
		"#server/*": "./app/server/*"
	},
	"main": "./app/server/main.js",
	"name": "aromachef.ru",
	"pre-commit": [
		"lint-format",
		"test"
	],
	"private": true,
	"scripts": {
		"build": "rolldown -c && postcss src/client/css/*.css -d public/bundles && node ./tools/build-static-pages.js",
		"build:vendors": "rolldown -c && npm run build:vendors:oxide",
		"build:vendors:oxide": "postcss src/client/vendors/oxide/*.css -d public/vendors/skins/ui/oxide",
		"dev": "dotenvx run -- nodemon ./src/server/main.js",
		"dump": "dotenvx run -- node ./tools/dump.js",
		"images": "dotenvx run -- node ./tools/images.js",
		"lint": "npm run type-check && biome check",
		"lint-format": "npm run type-check && biome check --write",
		"postinstall": "npm run build:vendors",
		"preview": "dotenvx run -- node ./src/server/main.js",
		"test": "npm run build && dotenvx run -- node --test",
		"test:ci": "npm run build && node --test",
		"type-check": "tsc -p ./tsconfig.json",
		"upgrade": "dotenvx run -- node ./tools/upgrade.js"
	},
	"type": "module"
}
